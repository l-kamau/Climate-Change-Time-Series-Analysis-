      },
      "source": [
        "# ARIMA Model Fitting and Forecasting\n",
        "\n",
        "# Define the split point for training and testing\n",
        "# Using 80% for training, similar to the Random Forest model\n",
        "split_point = int(len(ts_data) * 0.8)\n",
        "\n",
        "train_arima = ts_data[:split_point]\n",
        "test_arima = ts_data[split_point:]\n",
        "\n",
        "# For simplicity, we'll use a fixed order (p,d,q) based on common practice and prior checks.\n",
        "# Suppress specific warnings from statsmodels\n",
        "warnings.filterwarnings(\"ignore\")\n",
        "\n",
        "# Fit the ARIMA model\n",
        "if not train_arima.empty:\n",
        "    arima_model = ARIMA(train_arima, order=(5,1,0))\n",
        "    arima_model_fit = arima_model.fit()\n",
        "    print(arima_model_fit.summary())\n",
        "else:\n",
        "    print(\"Training data for ARIMA is empty. Cannot fit model.\")\n",
        "    arima_model_fit = None\n",
        "\n",
        "\n",
        "# Make predictions if model was fit successfully\n",
        "if arima_model_fit is not None:\n",
        "    # Forecast for the test period\n",
        "    arima_predictions = arima_model_fit.forecast(steps=len(test_arima))\n",
        "\n",
        "    # Evaluate the model\n",
        "    rmse_arima = np.sqrt(mean_squared_error(test_arima, arima_predictions))\n",
        "    print(f\"\\nARIMA RMSE: {rmse_arima:.2f}\")\n",
        "\n",
        "    # Plot actual vs. predicted values\n",
        "    plt.figure(figsize=(12, 6))\n",
        "    plt.plot(train_arima.index, train_arima, label='Training Data')\n",
        "    plt.plot(test_arima.index, test_arima, label='Actual Avg Temp')\n",
        "    plt.plot(test_arima.index, arima_predictions, label='ARIMA Predictions', linestyle='--')\n",
        "    plt.title('ARIMA Model: Actual vs. Predicted Average Temperature')\n",
        "    plt.xlabel('Date')\n",
        "    plt.ylabel('Average Temperature (°C)')\n",
        "    plt.legend()\n",
        "    plt.grid(True)\n",
        "    plt.show()\n",
        "else:\n",
        "    print(\"Skipping prediction and plotting due to empty training data.\")"
