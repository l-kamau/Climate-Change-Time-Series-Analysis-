      "source": [
        "# Filling missing data\n",
        "# 1. Linear Interpolation for Gradual Trends\n",
        "trend_cols = ['Avg_Temp (°C)', 'Max_Temp (°C)', 'Min_Temp (°C)', 'CO2_Concentration (ppm)', 'Sea_Surface_Temp (°C)']\n",
        "climate_data[trend_cols] = climate_data[trend_cols].interpolate(method='linear', limit_direction='both')\n",
        "\n",
        "# 2. Seasonal Mean for Weather (Month-by-Month average)\n",
        "seasonal_cols = ['Precipitation (mm)', 'Humidity (%)', 'Cloud_Cover (%)', 'Wind_Speed (m/s)', 'Solar_Irradiance (W/m²)']\n",
        "for col in seasonal_cols:\n",
        "    climate_data[col] = climate_data[col].fillna(climate_data.groupby('Month')[col].transform('mean'))\n",
        "\n",
        "# 3. Forward Fill for Geography & Indices\n",
        "static_cols = ['Latitude', 'Longitude', 'Altitude (m)', 'Proximity_to_Water (km)', 'ENSO_Index']\n",
        "climate_data[static_cols] = climate_data[static_cols].ffill().bfill()\n",
        "\n",
        "# 4. Foward fill for the 'Year' and 'Month' columns\n",
        "climate_data['Year'] = climate_data['Year'].ffill()\n",
        "climate_data['Month'] = climate_data['Month'].ffill()\n",
        "climate_data['Year'] = climate_data['Year'].ffill().bfill() # Forward fill then Backward fill to catch edges\n",
        "\n",
        "# List of columns that still have 1-4 missing values\n",
        "final_cleanup = [\n",
        "    'Precipitation (mm)', 'Solar_Irradiance (W/m²)', 'Cloud_Cover (%)',\n",
        "    'Urbanization_Index', 'Vegetation_Index', 'Particulate_Matter (µg/m³)'\n",
        "]\n",
        "\n",
        "# 5. Fill with median to keep data distribution realistic\n",
        "for col in final_cleanup:\n",
        "    climate_data[col] = climate_data[col].fillna(climate_data[col].median())\n",
        "\n",
        "# 6. The ultimate check\n",
        "climate_data.isnull().sum()"
      ]
    },
