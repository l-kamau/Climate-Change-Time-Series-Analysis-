      "source": [
        "# Cleaning up the column names and the strings\n",
        "# 1. Format Column Names\n",
        "# .strip() removes hidden spaces, .lower() sets them to small letters\n",
        "climate_data.columns = climate_data.columns.str.strip().str.lower()\n",
        "\n",
        "# 2. Trim and Capitalize String Data\n",
        "# We identify all columns containing text (objects)\n",
        "string_columns = climate_data.select_dtypes(include=['object']).columns\n",
        "\n",
        "for col in string_columns:\n",
        "    # Remove leading/trailing whitespace\n",
        "    climate_data[col] = climate_data[col].str.strip()\n",
        "\n",
        "    # Change capitalization to 'Title Case' (e.g., \"sunny\" -> \"Sunny\")\n",
        "    # You can also use .str.lower() or .str.upper() here\n",
        "    climate_data[col] = climate_data[col].str.title()\n",
        "\n",
        "# 3. Standardize Column Names\n",
        "# - Strip whitespace\n",
        "# - Lowercase everything\n",
        "# - Replace spaces/parentheses with underscores\n",
        "# - Clean up double underscores\n",
        "climate_data.columns = (\n",
        "    climate_data.columns\n",
        "    .str.strip()\n",
        "    .str.lower()\n",
        "    .str.replace(r'[ /()°%²µ]', '_', regex=True)\n",
        "    .str.replace(r'_+', '_', regex=True)\n",
        "    .str.strip('_')\n",
        ")\n",
        "\n",
        "# Trim and Standardize String Data\n",
        "string_cols = climate_data.select_dtypes(include=['object']).columns\n",
        "\n",
